{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ByteTable",
  "mainBinaryName": "bytetable",
  "version": "0.0.13",
  "identifier": "com.bytetable.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ByteTable",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 400,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Developer Tool",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "./linux/app.desktop"
      },
      "rpm": {
        "desktopTemplate": "./linux/app.desktop"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rezwanul-Haque/byteTable/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFOTcyNDNEQ0QzRUVFQUEKUldTcTdqN05QU1NYZmsxaUZEQ3RaY0g5MFEwMk01WkxMa1NjRmdJK2srdTN6bURvWjI3QTVrUkMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

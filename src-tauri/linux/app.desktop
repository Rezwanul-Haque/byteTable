[Desktop Entry]
Categories={{categories}}
{{#if comment}}Comment={{comment}}
{{/if}}Exec={{exec}}
Icon={{icon}}
Name={{name}}
Terminal=false
Type=Application
StartupNotify=true
# StartupWMClass maps the running WINDOW (X11 WM_CLASS / Wayland app_id) to THIS
# entry, so the dock shows the bundled icon AND the running-window dot instead of
# a generic fallback. It must equal the class the window reports. The window's
# class comes from `mainBinaryName` (= `bytetable`), and GNOME lowercases the
# app_id before looking up `<app_id>.desktop` — so the binary, this value, and the
# installed file name are ALL the lowercase token `bytetable`. A capitalized value
# here (or productName-cased file like `ByteTable.desktop`) silently fails to bind.
StartupWMClass=bytetable
